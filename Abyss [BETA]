-- หา Lobby ที่ใกล้ที่สุด
local function getNearestLobbyPart()
    local lobby = workspace:WaitForChild("Map"):WaitForChild("Lobby")
    local hrp = getHRP()

    local nearest, dist = nil, math.huge

    for _, obj in pairs(lobby:GetChildren()) do
        if obj:IsA("BasePart") then
            local d = (obj.Position - hrp.Position).Magnitude
            if d < dist then
                dist = d
                nearest = obj
            end
        elseif obj:IsA("Model") and obj.PrimaryPart then
            local d = (obj.PrimaryPart.Position - hrp.Position).Magnitude
            if d < dist then
                dist = d
                nearest = obj.PrimaryPart
            end
        end
    end

    return nearest
end

