local function getRoot()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    return char:WaitForChild("HumanoidRootPart")
end

-- หา Model ปลาที่ใกล้สุดในระยะ 10
local function getNearestFish()
    local root = getRoot()
    local nearest = nil
    local shortestDistance = 10 -- จำกัดระยะ 10 studs

    local fishFolder = workspace
        :WaitForChild("Game")
        :WaitForChild("Fish")
        :WaitForChild("client")

    for _, fish in ipairs(fishFolder:GetChildren()) do
        if fish:IsA("Model") and fish.PrimaryPart then
            local distance = (fish.PrimaryPart.Position - root.Position).Magnitude
            if distance <= shortestDistance then
                shortestDistance = distance
                nearest = fish
            end
        end
    end

    return nearest
end

