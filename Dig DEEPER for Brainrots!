-- ฟังก์ชันวาป
local function teleportToPosition(pos)
    local char = game:GetService("Players").LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = CFrame.new(pos)
    end
end

local function teleportTo(part)
    if part and part:IsA("BasePart") then
        teleportToPosition(part.Position + Vector3.new(0,3,0))
    elseif part and part:IsA("Model") then
        local p = part:FindFirstChildWhichIsA("BasePart")
        if p then
            teleportToPosition(p.Position + Vector3.new(0,3,0))
        end
    end
end

-- กด Prompt
local function firePrompt(obj)
    if obj and obj:IsA("ProximityPrompt") then
        fireproximityprompt(obj)
    end
end

-- Toggle
Tab:Toggle({
    Title = "ออโต้เก็บ Brainrots",
    Value = false,
    Callback = function(v)
        enabled = v

        if enabled then
            task.spawn(function()
                while enabled do
                    
                    -- 1️⃣ วาปไปพิกัดเริ่มต้น
                    teleportToPosition(Vector3.new(-1008.00061, 424.983398, -640))
                    task.wait(1)

                    -- หา Brainrots
                    local brainrotsFolder = workspace:FindFirstChild("Zones")
                        and workspace.Zones:FindFirstChild("Visuals")
                        and workspace.Zones.Visuals:FindFirstChild("Celestial")
                        and workspace.Zones.Visuals.Celestial:FindFirstChild("Brainrots")
                        and workspace.Zones.Visuals.Celestial.Brainrots:FindFirstChild("Brainrots")

                    -- 2️⃣ กดตามจำนวนที่เลือก
                    if brainrotsFolder then
                        for i = 1, selectedAmount do
                            for _, v in pairs(brainrotsFolder:GetDescendants()) do
                                if v:IsA("ProximityPrompt") then
                                    firePrompt(v)
                                    task.wait(0.01)
                                end
                            end
                        end
                    else
                        warn("ไม่เจอ Brainrots")
                    end

                    -- 3️⃣ วาปไป Common
                    local common = workspace:FindFirstChild("Zones")
                        and workspace.Zones:FindFirstChild("Visuals")
                        and workspace.Zones.Visuals:FindFirstChild("Common")

                    if common then
                        teleportTo(common)
                    else
                        warn("ไม่เจอ Common")
                    end

                    task.wait(0.1)

                    -- 4️⃣ วาปไป Event Reward
                    local reward = workspace:FindFirstChild("Event Reward")
                    if reward then
                        local stand = reward:FindFirstChild("Stand")
                        if stand and stand:FindFirstChild("Brainrot") then
                            local mesh = stand.Brainrot:FindFirstChild("Normal")
                                and stand.Brainrot.Normal:FindFirstChild("Mesh")

                            if mesh then
                                teleportTo(mesh)
                            else
                                warn("ไม่เจอ Mesh")
                            end
                        end
                    else
                        warn("ไม่เจอ Event Reward")
                    end

                    task.wait(0.1)
                end
            end)
