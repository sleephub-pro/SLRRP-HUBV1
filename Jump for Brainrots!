Tab:Toggle({
	Title = "ออโต้วาปไปดก็บตัวที่เงินเยอะที่สุด",
	Desc = "",
	Value = false,
	Callback = function(v)
		ToggleState = v

		if v and not Working then
			Working = true

			task.spawn(function()
				while ToggleState do
					task.wait(0.1)

					local brainrotsFolder = workspace:FindFirstChild("Brainrots")
					if not brainrotsFolder then continue end

					local highestValue = 0
					local highestModel = nil

					-- 🔎 หา Model ที่เงินมากที่สุด
					for _, model in pairs(brainrotsFolder:GetChildren()) do
						local textLabel = model:FindFirstChild("PriceLabel", true)
						if textLabel and textLabel:IsA("TextLabel") then
							local value = GetValueFromText(textLabel.Text)

							if value > highestValue then
								highestValue = value
								highestModel = model
							end
						end
					end

					if highestModel then
						local part = highestModel:FindFirstChildWhichIsA("BasePart", true)
						if part then
							-- 🚀 วาปไป
							TeleportTo(part)
							task.wait(0.25)

							-- 🖱 กด Prompt
							local prompt = highestModel:FindFirstChildWhichIsA("ProximityPrompt", true)
							if prompt then
								fireproximityprompt(prompt)
