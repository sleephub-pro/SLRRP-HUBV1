local Lighting = game:GetService("Lighting")

-- สร้างหรือดึงเอฟเฟกต์
local function getOrCreate(className, name)
    local obj = Lighting:FindFirstChild(name)
    if not obj then
        obj = Instance.new(className)
        obj.Name = name
        obj.Parent = Lighting
    end
    return obj
end

local ColorCorrection = getOrCreate("ColorCorrectionEffect", "CustomColorCorrection")
local Bloom = getOrCreate("BloomEffect", "CustomBloom")
local SunRays = getOrCreate("SunRaysEffect", "CustomSunRays")
local DOF = getOrCreate("DepthOfFieldEffect", "CustomDepthOfField")

local enabled = false
local intensity = 25

local function applyVisuals()
    if not enabled then
        ColorCorrection.Enabled = false
        Bloom.Enabled = false
        SunRays.Enabled = false
        DOF.Enabled = false
        return
    end

    ColorCorrection.Enabled = true
    Bloom.Enabled = true
    SunRays.Enabled = true
    DOF.Enabled = true

    local v = math.clamp(intensity, 0, 100)
    local p = v / 100

    -- สีสดขึ้น / คอนทราสต์ / ความสว่าง
    ColorCorrection.Brightness = 0.03 + (p * 0.12)
    ColorCorrection.Contrast = 0.08 + (p * 0.35)
    ColorCorrection.Saturation = 0.10 + (p * 0.60)
    ColorCorrection.TintColor = Color3.fromRGB(255, 245, 235)

    -- แสงฟุ้ง
    Bloom.Intensity = 0.15 + (p * 1.5)
    Bloom.Size = 12 + math.floor(p * 20)
    Bloom.Threshold = 1 - (p * 0.35)

    -- แสงแดด
    SunRays.Intensity = 0.02 + (p * 0.18)
    SunRays.Spread = 0.6 + (p * 0.35)

    -- เบลอระยะไกลเล็กน้อย เพิ่มมิติ
    DOF.FarIntensity = 0.05 + (p * 0.25)
    DOF.FocusDistance = 25
    DOF.InFocusRadius = 45
    DOF.NearIntensity = 0
end

Extra:Toggle({
    Title = "ทำให้ภาพสวย",
    Desc = "",
    Value = false,
    Callback = function(v)
        enabled = v
        applyVisuals()
    end
})





