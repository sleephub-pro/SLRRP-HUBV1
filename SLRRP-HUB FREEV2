repeat task.wait() until game:IsLoaded()

local placeId = game.PlaceId

local supported = {
    [124473577469410] = { -- Be a Lucky Block
        url = "https://raw.githubusercontent.com/sleephub-pro/SLRRP-HUBV1/refs/heads/main/Be%20a%20Lucky%20Block",
        name = "Be a Lucky Block"
    },
local supported = {
    [84514721527976] = { -- Dig DEEPER for Brainrots!
        url = "https://raw.githubusercontent.com/sleephub-pro/SLRRP-HUBV1/refs/heads/main/Dig%20DEEPER%20for%20Brainrots!",
        name = "Dig DEEPER for Brainrots!"
    }
}

local data = supported[placeId]

if data then
    local success, err = pcall(function()
        loadstring(game:HttpGet(data.url))()
    end)

    if success then
        print("Loaded: " .. data.name)
    else
        warn("Script load failed for " .. data.name .. " → " .. tostring(err))
        game.Players.LocalPlayer:Kick("ดาวน์โหลดสคริปต์ไม่สำเร็จ")
    end
else
    game.Players.LocalPlayer:Kick("ไม่รองรับเกมนี้")
    task.wait(3)
    game:Shutdown()
end
