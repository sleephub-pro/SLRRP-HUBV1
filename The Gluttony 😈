Tab:Toggle({
    Title = "เพิ่มระยะดารโจมตี",
    Desc = "",
    Value = false,
    Callback = function(v)
        getgenv().HitboxToggle = v

        local player = game.Players.LocalPlayer

        -- ฟังก์ชันขยาย Hitbox
        local function applyHitbox(char)
            for _, tool in pairs(char:GetChildren()) do
                if tool:IsA("Tool") then
                    local hitbox = tool:FindFirstChild("Hitbox")
                    if hitbox and hitbox:IsA("BasePart") then
                        if not hitbox:FindFirstChild("OldSize") then
                            local old = Instance.new("Vector3Value")
                            old.Name = "OldSize"
                            old.Value = hitbox.Size
                            old.Parent = hitbox
                        end

                        hitbox.Size = hitbox:FindFirstChild("OldSize").Value * 100
                        hitbox.Massless = true
                        hitbox.CanCollide = false
                    end
                end
            end
        end

        -- ฟังก์ชันรีเซ็ต
        local function resetHitbox(char)
            for _, tool in pairs(char:GetChildren()) do
                if tool:IsA("Tool") then
                    local hitbox = tool:FindFirstChild("Hitbox")
                    if hitbox and hitbox:IsA("BasePart") then
                        local old = hitbox:FindFirstChild("OldSize")
                        if old then
                            hitbox.Size = old.Value
                        end
                    end
                end
            end
        end

        -- Loop หลัก
        task.spawn(function()
            while getgenv().HitboxToggle do
                local char = player.Character
                if char then
                    applyHitbox(char)

                    -- ดัก Tool ใหม่
                    char.ChildAdded:Connect(function(obj)
                        if getgenv().HitboxToggle and obj:IsA("Tool") then
                            task.wait(0.1)
                            applyHitbox(char)
                        end
                    end)
                end
                task.wait(1)
            end

            -- ตอนปิด → รีเซ็ต
            if player.Character then
                resetHitbox(player.Character)
            end
        end)

        -- ดักตอนตาย / เกิดใหม่
        player.CharacterAdded:Connect(function(char)
            if getgenv().HitboxToggle then
                repeat task.wait() until char.Parent
                applyHitbox(char)
            end
        end)
    end
})






